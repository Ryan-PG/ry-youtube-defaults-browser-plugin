{
  "manifest_version": 3,
  "name": "YouTube Default Settings",
  "version": "1.0.0",
  "description": "Automatically apply your default playback quality and speed on YouTube - both for videos and Shorts. Works on Chrome and Firefox.",
  "permissions": ["storage"],

  "content_scripts": [
    {
      "matches": ["*://*.youtube.com/*"],
      "js": ["content.js"],
      "run_at": "document_start"
    }
  ],

  "action": {
    "default_popup": "popup.html",
    "default_title": "YouTube Default Settings",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },

  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },

  "browser_specific_settings": {
    "gecko": {
      "id": "yt-default-settings@example.com",
      "strict_min_version": "115.0"
    }
  }
}
